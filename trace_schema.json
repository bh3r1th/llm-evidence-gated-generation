{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ega/trace_schema.json",
  "title": "EGA Trace Row",
  "type": "object",
  "$comment": "Pipeline rows are full; shell error rows may be partial. Keep schema permissive.",
  "additionalProperties": true,
  "required": [
    "total_seconds",
    "read_seconds",
    "unitize_seconds",
    "verify_seconds",
    "enforce_seconds",
    "polish_seconds"
  ],
  "properties": {
    "trace_schema_version": {"type": "integer", "minimum": 1},
    "total_seconds": {"type": "number", "minimum": 0},
    "read_seconds": {"type": "number", "minimum": 0},
    "unitize_seconds": {"type": "number", "minimum": 0},
    "verify_seconds": {"type": "number", "minimum": 0},
    "load_seconds": {"type": "number", "minimum": 0},
    "verify_compute_seconds": {"type": "number", "minimum": 0},
    "enforce_seconds": {"type": "number", "minimum": 0},
    "polish_seconds": {"type": "number", "minimum": 0},
    "preselect_seconds": {"type": "number", "minimum": 0},
    "tokenize_seconds": {"type": "number", "minimum": 0},
    "forward_seconds": {"type": "number", "minimum": 0},
    "post_seconds": {"type": "number", "minimum": 0},
    "num_batches": {"type": "integer", "minimum": 0},
    "batch_size_mean": {"type": "number", "minimum": 0},
    "batch_size_max": {"type": "integer", "minimum": 0},
    "seq_len_mean": {"type": "number", "minimum": 0},
    "seq_len_p50": {"type": "number", "minimum": 0},
    "seq_len_p95": {"type": "number", "minimum": 0},
    "tokens_total": {"type": "integer", "minimum": 0},
    "device": {"type": ["string", "null"]},
    "dtype": {"type": ["string", "null"]},
    "amp_enabled": {"type": "boolean"},
    "compiled_enabled": {"type": "boolean"},
    "pairs_pruned_stage1": {"type": "integer", "minimum": 0},
    "pairs_pruned_stage2": {"type": "integer", "minimum": 0},
    "dtype_overridden": {"type": "boolean"},
    "evidence_truncated_frac": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_chars_mean_before": {"type": "number", "minimum": 0},
    "evidence_chars_mean_after": {"type": "number", "minimum": 0},
    "rerank_seconds": {"type": "number", "minimum": 0},
    "rerank_pairs_scored": {"type": "integer", "minimum": 0},
    "conformal_threshold": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "conformal_abstain_units": {"type": "integer", "minimum": 0},
    "budget_topk_per_unit": {"type": ["integer", "null"], "minimum": 0},
    "budget_max_pairs_total": {"type": ["integer", "null"], "minimum": 0},
    "n_units": {"type": "integer", "minimum": 0},
    "n_evidence": {"type": "integer", "minimum": 0},
    "n_pairs": {"type": "integer", "minimum": 0},
    "n_pairs_scored": {"type": "integer", "minimum": 0},
    "kept_units": {"type": "integer", "minimum": 0},
    "dropped_units": {"type": "integer", "minimum": 0},
    "refusal": {"type": "boolean"},
    "model_name": {"type": ["string", "null"]}
    ,
    "coverage_pool_topk": {"type": "integer", "minimum": 0},
    "coverage_avg_score": {"type": "number", "minimum": 0, "maximum": 1},
    "coverage_unit_scores": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "coverage_missing_total": {"type": "integer", "minimum": 0},
    "reward_total": {"type": "number"},
    "reward_avg": {"type": "number"},
    "reward_avg_support": {"type": "number", "minimum": 0, "maximum": 1},
    "reward_hallucination_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "reward_abstention_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "reward_avg_coverage": {"type": "number", "minimum": 0, "maximum": 1},
    "reward_unit_totals": {
      "type": "object",
      "additionalProperties": {"type": "number"}
    }
  }
}
