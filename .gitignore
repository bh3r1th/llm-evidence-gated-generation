# ==================================
# Python bytecode / caches
# ==================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
pytest_temp/
.ruff_cache/
.mypy_cache/

# ==================================
# Packaging / build
# ==================================
*.egg-info/
build/
dist/
pip-wheel-metadata/

# ==================================
# Virtual environments
# ==================================
.venv/
venv/
env/
.env
.env.*

# ==================================
# Coverage artifacts
# ==================================
.coverage
.coverage.*
coverage.xml
htmlcov/

# ==================================
# Logs
# ==================================
*.log
logs/

# ==================================
# Temporary repo folders
# ==================================
manual_test_tmp/
tmp_manual_checks/
pytest_temp/

# ==================================
# Model cache
# ==================================
.hf/

# ==================================
# Editors / OS
# ==================================
.vscode/
.idea/
.DS_Store

# ==================================
# Optional: ignore raw experiment junk
# but KEEP curated evaluation outputs
# ==================================
runs/*/debug/
runs/*/tmp/